# Container image injected by CI at deploy time.
# APP_IMAGE=ghcr.io/your-org/yuan-backend-admin:sha-xxxxxxxxxxxx

TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms512m -Xmx1024m

APP_PORT_BIND=127.0.0.1:6011:6011
MYSQL_PORT_BIND=3306:3306
REDIS_PORT_BIND=6379:6379
MINIO_API_PORT_BIND=9000:9000
MINIO_CONSOLE_PORT_BIND=9001:9001

DATA_ROOT=./runtime
CONFIG_DIR=./config
LOGS_DIR=./logs

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=yuan
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

REDIS_PASSWORD=change-me
SPRING_REDIS_PASSWORD=change-me

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me
OSS_STORAGE=S3_COMPATIBLE
OSS_BUCKET=yuan
OSS_PRESIGN_EXPIRE_SECONDS=600
OSS_S3_ENDPOINT=minio:9000
OSS_S3_ACCESS_KEY=admin
OSS_S3_SECRET_KEY=change-me
OSS_S3_REGION=us-east-1
OSS_S3_PATH_STYLE_ACCESS=true

# Optional AI overrides
# SPRING_AI_OPENAI_API_KEY=
# SPRING_AI_OPENAI_BASE_URL=
