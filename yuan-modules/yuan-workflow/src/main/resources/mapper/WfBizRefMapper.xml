<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuan.workflow.mapper.WfBizRefMapper">

    <select id="selectByInstanceId" resultType="com.yuan.workflow.domain.WfBizRef">
        select *
        from wf_biz_ref wbr
        where wbr.instance_id = #{instanceId}
    </select>
</mapper>
