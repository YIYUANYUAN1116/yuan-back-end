<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuan.system.mapper.SysTenantMapper">

    <select id="strSelectModel" resultType="com.yuan.common.core.domain.model.StrSelectModel">
        select st.tenant_id as value,
               st.company_name as label
        from sys_tenant st
        where st.status = 0 and st.del_flag = 0
    </select>
</mapper>
