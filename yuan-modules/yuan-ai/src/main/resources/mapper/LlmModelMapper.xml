<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuan.ai.mapper.LlmModelMapper">

    <select id="selectModel" resultType="com.yuan.common.core.domain.model.StrSelectModel">
        select display_name as label,
               model_name as value
        from llm_model
        where del_flag = 0 and status = 0 and endpoint_key = #{endpointKey}
    </select>
</mapper>
