<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuan.ai.mapper.LlmEndpointMapper">

    <select id="selectEndpointByProvider" resultType="com.yuan.common.core.domain.model.SelectModel">
        select id as value,
               endpoint_name as label
        from llm_endpoint
        where del_flag = 0 and status = 0 and provider_id = #{providerId}
    </select>
</mapper>
